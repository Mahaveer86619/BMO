# ─── LOCAL DEVELOPMENT (Windows + Ollama installed natively) ───────────────────
# Ollama container is skipped; the app talks to your host machine's Ollama.
# host.docker.internal resolves to your Windows host from inside Docker Desktop.
#
# COMPOSE_PROFILES=
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2:3b


# ─── FULL DOCKER DEPLOYMENT (Ollama runs as a container) ───────────────────────
# Uncomment these and comment out the section above.
#
# COMPOSE_PROFILES=ollama
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2:3b


# ─── STT ───────────────────────────────────────────────────────────────────────
# STT_PROVIDER=local            # faster-whisper, runs in-container (default)
# STT_PROVIDER=huggingface      # HF Inference API — needs HF_API_TOKEN below

# HF_API_TOKEN=hf_xxxxxxxxxxxx  # only needed when STT_PROVIDER=huggingface
# HF_WHISPER_MODEL=openai/whisper-base


# ─── DATABASE ──────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD=bmo_pass    # change in production
