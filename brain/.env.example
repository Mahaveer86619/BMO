# Copy this to .env and fill in your values.
# .env is the single source of truth — docker-compose reads it directly.

# ─── OLLAMA (LLM) ───────────────────────────────────────────────────────────────
# Local dev: Ollama installed natively on Windows, app reaches it via Docker bridge
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b

# Full Docker: uncomment below + set COMPOSE_PROFILES=ollama
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2:3b
# COMPOSE_PROFILES=ollama

COMPOSE_PROFILES=


# ─── STT ────────────────────────────────────────────────────────────────────────
STT_PROVIDER=local          # local | huggingface
WHISPER_MODEL=base

# Only needed when STT_PROVIDER=huggingface
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# HF_WHISPER_MODEL=openai/whisper-base


# ─── TTS ────────────────────────────────────────────────────────────────────────
TTS_PROVIDER=piper          # piper (fast, generic voice) | xtts (BMO voice clone, needs reference.wav)


# ─── DATABASE ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string — leave empty to disable DB features (reminders).
# Matches the db service credentials in docker-compose.yml.
DATABASE_URL=postgresql://bmo:bmo_pass@db:5432/bmo_db


# ─── TOOLS ──────────────────────────────────────────────────────────────────────
# Default city for the weather tool when the user doesn't specify a location.
DEFAULT_WEATHER_LOCATION=London


# ─── WAKE WORD ──────────────────────────────────────────────────────────────────
# Leave empty to disable. When set, audio without this word is silently dropped.
WAKE_WORD=


# ─── MINIO (audio storage) ──────────────────────────────────────────────────────
# Local: MinIO runs as a Docker service (minio:9000 inside compose network).
# Console UI available at http://localhost:9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=bmo
MINIO_SECRET_KEY=bmo_secret
MINIO_BUCKET=bmo-audio
MINIO_SECURE=false


# ─── LOGGING ────────────────────────────────────────────────────────────────────
# dev     : full bmo pipeline steps (STT/CMD/LLM payloads/tool calls) — no third-party noise
# verbose : everything at DEBUG, including httpcore/httpx/multipart internals
# alerts  : standard operational logs (default)
# ignore  : warnings and errors only
LOG_LEVEL=alerts
